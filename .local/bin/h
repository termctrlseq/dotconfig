#!/usr/bin/env bash
#
# Show command's help page with syntax highlighting

if command -v bat >/dev/null 2>&1; then
  if [[ "$@" =~ .*-h ]]; then
    "$@" | bat -plhelp
  # Number of arguments is one
  elif (( "${#@}" == 1 )); then
    if "$1" --help >/dev/null 2>&1; then
      "$1" --help | bat -plhelp
    elif help "$1" >/dev/null 2>&1; then
      help "$1" | bat -plhelp
    elif "$1" -h >/dev/null 2>&1; then
      "$1" -h | bat -plhelp
    else
      echo -e "\e[1;31mError\e[0m: no help found for command '$*'"
      exit 1
    fi
  # Number of arguments is greater than one
  elif (( "${#@}" > 1 )); then
    if "$1" "help" "${@:2}" >/dev/null 2>&1; then
      "$1" "help" "${@:2}" | bat -plhelp
    elif "$@" --help >/dev/null 2>&1; then
      "$@" --help | bat -plhelp
    else
      echo -e "\e[1;31mError\e[0m: no help found for command '$*'"
      exit 1
    fi
  else
    echo "Usage: h [COMMAND] [SUBCOMMAND]" | bat -plhelp
  fi
else
  echo -e "\e[1;31mError\e[0m: \e[1mbat\e[0m: not found"
  exit 1
fi
