#
# ~/.inputrc
#

set editing-mode vi
set show-mode-in-prompt on

set vi-cmd-mode-string "\1\e[1;38;5;211m\2[c]\1\e[0m\e[2 q\2"
set vi-ins-mode-string "\1\e[1;38;5;8m\2|i|\1\e[0m\e[6 q\2"
set emacs-mode-string "\1\e[1;38;5;11m\2[@]\1\e[0m\e[2 q\2"

set colored-completion-prefix on
set colored-stats on
set completion-map-case on
set convert-meta off
set history-size 500
set show-all-if-unmodified on
set skip-completed-text on

"\em": menu-complete
