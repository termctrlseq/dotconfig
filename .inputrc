#
# ~/.inputrc
#

set editing-mode vi
set show-mode-in-prompt on

$if bash
set vi-cmd-mode-string "\1\e[1;38;5;5m\2[c]\1\e[0m\e[2 q\e]12;#ad8ee6\a\2"
set vi-ins-mode-string "\1\e[1;38;5;8m\2[i]\1\e[0m\e[6 q\e]12;#7478a1\a\2"
set emacs-mode-string "\1\e[1;38;5;11m\2[@]\1\e[0m\e[2 q\e]12;#ff9e64\a\2"
$else
set vi-cmd-mode-string "\1\e[2 q\e]12;#ad8ee6\a\2"
set vi-ins-mode-string "\1\e[6 q\e]12;#7478a1\a\2"
set  emacs-mode-string "\1\e[2 q\e]12;#ff9e64\a\2"
$endif

set colored-completion-prefix on
set colored-stats on
set completion-map-case on
set history-size 500
set revert-all-at-newline on
set show-all-if-unmodified on
set skip-completed-text on
