# vim: ft=sh
#
# ~/.bindrc
#
# shellcheck disable=SC2016,SC2086

# Attempt to perform completion on the text before point
bind -m vi-command  '"\t":   complete'
bind -m vi-insert   '"\t":   complete'
# Attempt menu completion from the history list
bind -m vi-command  '"\ed":  dabbrev-expand'
bind -m vi-insert   '"\ed":  dabbrev-expand'

# Perform history expansion on the current line
bind -m vi-command  '"\ef":  history-expand-line'
bind -m vi-insert   '"\ef":  history-expand-line'
# Perform glob expansions
bind -m vi-command  '"\eg":  glob-expand-word'
bind -m vi-insert   '"\eg":  glob-expand-word'

# Drag the word before point past the word after point
bind -m vi-command  '"\C-t": transpose-words'
bind -m vi-insert   '"\C-t": transpose-words'

# Clear screen
bind -m vi-command  '"\C-\M-l": clear-screen'
# Execute readline command
bind -m vi-command  '"\ee":  execute-named-command'

# Uppercase previous (or current) word
upcase_word() {
    local line word i j
    line="$READLINE_LINE" # typed line
    i="$READLINE_POINT"   # cursor position
    j="$READLINE_POINT"
    # find index of the beginning of the word under cursor
    while ((i > 0)) && [[ "${line:${i}-1:1}" =~ [a-zA-Z0-9_] ]]; do ((i--)); done
    # find index of the end of the word under cursor
    while [[ "${line:${j}:1}" =~ [a-zA-Z0-9_] ]]; do ((j++)); done
    # word under cursor (start=i; length=j-i)
    word="${line:${i}:$((j - i))}"
    # combine: line before word, upper-cased word, line after word
    READLINE_LINE="${line:0:${i}}${word@U}${line: ${j}}"
}
bind -m vi-command -x '"\C-b": upcase_word'
bind -m vi-insert  -x '"\C-b": upcase_word'

# invoke the manual for the command preceding the cursor by pressing Alt+h.
run-help() { h $READLINE_LINE; }
bind -m vi-command -x '"\eh": run-help'
bind -m vi-insert  -x '"\eh": run-help'
bind -m emacs      -x '"\eh": run-help'

# start ptpython with Alt-p
start-ptpython() {
    local pt_prompt="\[\e[1;38;5;8m\][i]${PS1}\[\e[1;38;5;8m\]=> \[\e[0m\]"
    local pt_tmp
    pt_tmp="$(mktemp)"
    local keycode
    keycode="$(xmodmap -pke | grep 'keycode\s\+36')"
    xmodmap -e 'keycode  36 = Escape'
    pt_live.py "${pt_tmp}" "${pt_prompt@P}"
    xmodmap -e "${keycode}"
    if [[ -f "$pt_tmp" ]]; then
        read -r READLINE_LINE < "$pt_tmp"
        READLINE_POINT="${#READLINE_LINE}"
        rm -f "$pt_tmp"
        ydotool key 28:1 28:0 28:1 28:0
    fi
}
bind -m vi-command -x '"\ep": start-ptpython'
bind -m vi-insert  -x '"\ep": start-ptpython'
